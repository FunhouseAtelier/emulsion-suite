# =============================================================================
# Emulsion Suite — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment & secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
*.pem
*.key
credentials.json
secrets.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.so

# Virtual environments
.venv/
venv/
ENV/
env/

# uv
uv.lock

# ---------------------------------------------------------------------------
# Node.js / pnpm
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
*.tgz

# ---------------------------------------------------------------------------
# Vite / Build output
# ---------------------------------------------------------------------------
# Built island bundles (regenerated by `emulsion build`)
**/static/islands/
**/static/assets/
**/static/.vite/

# Vite cache
.vite/

# TypeScript build output (regenerated by `pnpm build`)
packages/emulsion-react/dist/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Desktop.ini
ehthumbs.db

# ---------------------------------------------------------------------------
# Exports (generated by emulsion-export extension)
# ---------------------------------------------------------------------------
exports/

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
.claude/
